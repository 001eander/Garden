{
    "$schema": "https://opencode.ai/config.json",
    "model": "openai/gpt-5.4",
    "small_model": "deepseek/deepseek-chat",
    "default_agent": "iris",
    "agent": {
        "build": {
            "disable": true
        },
        "plan": {
            "disable": true
        }
    },
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            },
            "enabled": true
        },
        "chrome-devtools": {
            "type": "local",
            "command": [
                "pnpm",
                "dlx",
                "chrome-devtools-mcp@latest",
                "--autoConnect",
                "--channel=beta"
            ],
            "enabled": false
        }
    }
}

{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "iris",
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true,
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            }
        },
        "playwright": {
            "type": "local",
            "command": [
                "pnpm",
                "dlx",
                "@playwright/mcp@latest"
            ],
            "enabled": false
        }
    }
}